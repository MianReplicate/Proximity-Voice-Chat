--- !u!114 &6726400015927089120
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1450327976445928608}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec3b8824308adc64fb1901cef109132a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  mutators:
  - name: Proximity Voice Chat
    description: Modifies the Voice Chat Simulator to be proximity based!
    menuImage: {fileID: 2800000, guid: cc579fa7f77e47441ab1160037879ee7, type: 3}
    mutatorPrefab: {fileID: 1450327976445928608}
    configuration:
      labels:
      - id: 
        displayName: Actors that die above this distance do not play audio
        orderPriority: 6
      - id: 
        displayName: If the death audio is too far to be played, this resorts to
          the default voice chat implementation (Only applies to player kills)
        orderPriority: 12
      - id: 
        displayName: Note that using the default voice chat implementation will use
          the configuration you set on Voice Chat Simulator
        orderPriority: 13
      - id: 
        displayName: Chance of a full conversation playing between actors
        orderPriority: 29
      - id: 
        displayName: Chance of an actor pulling a oneliner
        orderPriority: 31
      - id: 
        displayName: The below options are relating to actors using proximity voice
          chat for chattering
        orderPriority: 27
      - id: 
        displayName: The below options are relating to voicelines playing upon death
          (REQUIRES VOICE CHAT SIMULATOR)
        orderPriority: 5
      - id: 
        displayName: The below options affect both death voicelines and chatter voicelines
        orderPriority: 2
      - id: 
        displayName: 'WARNING: This mutator has offensive content in it and is intended
          to only be used by adults!'
        orderPriority: 0
      - id: 
        displayName: 
        orderPriority: 25
      - id: 
        displayName: 
        orderPriority: 35
      - id: 
        displayName: 
        orderPriority: 4
      integers:
      - id: maxSounds
        displayName: Max Ongoing Sounds
        orderPriority: 6
        value: 6
      - id: maxDistanceHear
        displayName: Max Hearable Audio Distance (METERS)
        orderPriority: 4
        value: 40
      - id: maxDistancePlay
        displayName: Max Actor Distance from Player (METERS)
        orderPriority: 7
        value: 50
      floats:
      - id: audioDelay
        displayName: Audio Delay
        orderPriority: 6
        value: 0.5
      - id: minimumTime
        displayName: Minimum Time Between Voicelines (SECONDS)
        orderPriority: 28
        value: 10
      ranges:
      - id: volume
        displayName: Volume
        orderPriority: 3
        value:
          value: 0.75
          min: 0
          max: 1
          wholeNumbers: 0
      - id: audioChance
        displayName: Chance of Audio Playing
        orderPriority: 6
        value:
          value: 0.5
          min: 0
          max: 1
          wholeNumbers: 0
      - id: conversationChance
        displayName: Chance of Conversation Playing
        orderPriority: 30
        value:
          value: 0.2
          min: 0
          max: 1
          wholeNumbers: 0
      - id: onelinerChance
        displayName: Chance of One Liner Playing
        orderPriority: 32
        value:
          value: 0.9
          min: 0
          max: 1
          wholeNumbers: 0
      strings: []
      bools:
      - id: affectsPlayer
        displayName: Affects Player
        orderPriority: 6
        value: 0
      - id: playForFriendlyFire
        displayName: Play on Friendly Fire
        orderPriority: 6
        value: 1
      - id: playForPlayerTeam
        displayName: Affects Player Team
        orderPriority: 6
        value: 1
      - id: resortToVCIfTooFar
        displayName: Use Global Voice Chat If Too Far From Player
        orderPriority: 14
        value: 1
      - id: debug
        displayName: Debug Mode
        orderPriority: 102
        value: 0
      dropdowns: []
