  m_Script: {fileID: 11500000, guid: ec3b8824308adc64fb1901cef109132a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  mutators:
  - name: Proximity Voice Chat
    description: Modifies the Voice Chat Simulator to be proximity based!
    menuImage: {fileID: 2800000, guid: cc579fa7f77e47441ab1160037879ee7, type: 3}
    mutatorPrefab: {fileID: 1450327976445928608}
    configuration:
      labels:
      - id: 
        displayName: Actors that die above this distance do not play audio
        orderPriority: 7
      - id: 
        displayName: How far you can hear the audio
        orderPriority: 5
      - id: 
        displayName: If the audio is too far to be played, this resorts to the default
          voice chat implementation (Only applies to player kills)
        orderPriority: 99
      - id: 
        displayName: Note that using the default voice chat implementation will use
          the configuration you set on Voice Chat Simulator
        orderPriority: 100
      integers:
      - id: maxSounds
        displayName: Max Ongoing Sounds
        orderPriority: 4
        value: 6
      - id: maxDistanceHear
        displayName: Max Hearable Audio Distance
        orderPriority: 6
        value: 40
      - id: maxDistancePlay
        displayName: Max Actor Distance from Player
        orderPriority: 8
        value: 75
      floats:
      - id: audioDelay
        displayName: Audio Delay
        orderPriority: 1
        value: 0.5
      ranges:
      - id: volume
        displayName: Volume
        orderPriority: 0
        value:
          value: 0.5
          min: 0
          max: 1
          wholeNumbers: 0
      - id: audioChance
        displayName: Chance of Audio Playing
        orderPriority: 0
        value:
          value: 0.5
          min: 0
          max: 1
          wholeNumbers: 0
      strings: []
      bools:
      - id: affectsPlayer
        displayName: Affects Player
        orderPriority: 0
        value: 0
      - id: playForFriendlyFire
        displayName: Play on Friendly Fire
        orderPriority: 0
        value: 1
      - id: playForPlayerTeam
        displayName: Affects Player Team
        orderPriority: 0
        value: 1
      - id: resortToVCIfTooFar
        displayName: Use Global Voice Chat If Too Far From Player
        orderPriority: 101
        value: 1
      - id: debug
        displayName: Debug Mode
        orderPriority: 102
        value: 0
      dropdowns: []
